# Local-first defaults. Do not put real secrets in this file.

APP_ENV=development
LIFEMAP_DATA_DIR=./data
LIFEMAP_SQLITE_URL=sqlite:///./data/local.db

# Ollama local defaults
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Optional external provider. Leave empty unless explicitly used.
OPENAI_API_KEY=
OPENAI_MODEL=

# Source ingestion
SOURCE_FETCH_ENABLED=false
SOURCE_FETCH_RATE_LIMIT_PER_MINUTE=10
