# Local-first defaults. Do not put real secrets in this file.

APP_ENV=development
LIFEMAP_DATA_DIR=./data
LIFEMAP_SQLITE_URL=sqlite:///./data/local.db
# `stub` can still support local graph fallback, but Pathway intake follow-up questions require `openai`.
LIFEMAP_LLM_PROVIDER=stub
LIFEMAP_LLM_REQUEST_TIMEOUT_SECONDS=60
LIFEMAP_LLM_MAX_REPAIR_ATTEMPTS=2
LIFEMAP_GENERATION_QUERY_LIMIT=4
LIFEMAP_GENERATION_HITS_PER_QUERY=4
LIFEMAP_GENERATION_EVIDENCE_LIMIT=6
LIFEMAP_LANCEDB_URI=./data/lancedb
SOURCE_CHUNK_TARGET_TOKENS=700
SOURCE_CHUNK_OVERLAP_TOKENS=120

# Required for model-generated Pathway intake follow-up questions.
# Desktop Codex runs use Codex login + GPT-5.5.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Frontend safe public config
PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Source ingestion
SOURCE_FETCH_ENABLED=false
SOURCE_FETCH_RATE_LIMIT_PER_MINUTE=10
