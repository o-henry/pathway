# Local-first defaults. Do not put real secrets in this file.

APP_ENV=development
LIFEMAP_DATA_DIR=./data
LIFEMAP_SQLITE_URL=sqlite:///./data/local.db
# `codex` uses the logged-in Codex CLI session. `stub` is only for deterministic graph fallback.
LIFEMAP_LLM_PROVIDER=codex
LIFEMAP_CODEX_MODEL=gpt-5.5
# Enables Codex CLI live web search (`codex exec --search`) for research planning.
LIFEMAP_CODEX_WEB_SEARCH_ENABLED=true
# Optional loopback API guard. Desktop dev/app launch injects its own token automatically.
LIFEMAP_LOCAL_API_TOKEN=
LIFEMAP_LLM_REQUEST_TIMEOUT_SECONDS=180
# 0 means GraphBundle generation is allowed to run until Codex completes.
LIFEMAP_GRAPH_GENERATION_TIMEOUT_SECONDS=0
LIFEMAP_LLM_MAX_REPAIR_ATTEMPTS=2
LIFEMAP_GENERATION_QUERY_LIMIT=4
LIFEMAP_GENERATION_HITS_PER_QUERY=4
LIFEMAP_GENERATION_EVIDENCE_LIMIT=6
LIFEMAP_LANCEDB_URI=./data/lancedb
SOURCE_CHUNK_TARGET_TOKENS=700
SOURCE_CHUNK_OVERLAP_TOKENS=120

# Frontend safe public config
PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Source ingestion
SOURCE_FETCH_ENABLED=false
SOURCE_FETCH_RATE_LIMIT_PER_MINUTE=10
