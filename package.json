{
  "name": "pathway",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "pnpm --filter web exec vite dev --host 127.0.0.1 --port 5173",
    "dev:web:full": "node scripts/dev-reset.mjs web",
    "dev:desktop-ui": "pnpm --filter desktop dev",
    "dev:desktop:services": "node scripts/dev-reset.mjs desktop",
    "dev:desktop:full": "tauri dev",
    "dev:api": "UV_CACHE_DIR=.uv-cache uv run fastapi dev apps/api/lifemap_api/main.py --host 127.0.0.1 --port 8000",
    "dev:desktop": "tauri dev",
    "build": "pnpm --filter desktop build",
    "build:desktop": "tauri build",
    "check": "pnpm --filter desktop typecheck",
    "check:desktop": "cargo check --manifest-path src-tauri/Cargo.toml",
    "lint": "pnpm lint:web && pnpm lint:api",
    "lint:web": "pnpm --filter web lint",
    "lint:api": "uv run ruff check apps/api",
    "format:api": "uv run ruff format apps/api",
    "test": "pnpm test:web && pnpm test:api",
    "test:web": "pnpm --filter web test:unit -- --run",
    "test:web:e2e": "pnpm --filter web test:e2e",
    "playwright:install": "PLAYWRIGHT_BROWSERS_PATH=apps/web/.playwright-browsers pnpm --filter web exec playwright install chromium",
    "test:api": "uv run pytest",
    "typecheck": "pnpm --filter desktop typecheck",
    "secret-scan": "PRE_COMMIT_HOME=.pre-commit-cache UV_CACHE_DIR=.uv-cache uv run pre-commit run gitleaks --all-files"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.1",
    "concurrently": "^9.2.1"
  }
}
